// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "mysql"
}

model roles {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())
  users       users[]
  approval_steps approval_steps[]
}

model departments {
  id                Int                 @id @default(autoincrement()) @db.UnsignedInt
  code              String              @unique @db.VarChar(20)
  name              String              @db.VarChar(150)
  created_at        DateTime            @default(now())
  users             users[]
  purchase_requests purchase_requests[]
}

model users {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  employee_id   String   @unique @db.VarChar(50)
  first_name    String   @db.VarChar(100)
  last_name     String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  password_hash String   @db.VarChar(255)
  role_id       Int      @db.UnsignedInt
  department_id Int?     @db.UnsignedInt
  is_active     Boolean  @default(true)
  avatar_url    String?  @db.VarChar(500)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  roles                                         roles        @relation(fields: [role_id], references: [id])
  departments                                   departments? @relation(fields: [department_id], references: [id])
  refresh_tokens                                refresh_tokens[]
  purchase_requests                             purchase_requests[]
  pr_approvals                                  pr_approvals[]
  tracking_logs_tracking_logs_from_user_idTousers tracking_logs[] @relation("tracking_logs_from_user_idTousers")
  tracking_logs_tracking_logs_to_user_idTousers   tracking_logs[] @relation("tracking_logs_to_user_idTousers")
  notifications                                 notifications[]
  report_snapshots                              report_snapshots[]
}

model refresh_tokens {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id    Int      @db.UnsignedInt
  token      String   @unique @db.VarChar(512)
  expires_at DateTime
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model item_categories {
  id                Int                 @id @default(autoincrement()) @db.UnsignedInt
  code              String              @unique @db.VarChar(30)
  name              String              @db.VarChar(150)
  description       String?             @db.Text
  created_at        DateTime            @default(now())
  purchase_requests purchase_requests[]
  pr_line_items     pr_line_items[]
  ml_classifications ml_classifications[]
}

model purchase_requests {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  pr_number       String    @unique @db.VarChar(30)
  title           String    @db.VarChar(255)
  purpose         String    @db.Text
  requested_by    Int       @db.UnsignedInt
  department_id   Int       @db.UnsignedInt
  total_amount    Decimal   @default(0) @db.Decimal(15, 2)
  status          PRStatus  @default(DRAFT)
  priority        Priority  @default(NORMAL)
  ml_category_id  Int?      @db.UnsignedInt
  ml_confidence   Decimal?  @db.Decimal(5, 4)
  ml_raw_output   Json?
  date_needed     DateTime? @db.Date
  remarks         String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  users           users           @relation(fields: [requested_by], references: [id])
  departments     departments     @relation(fields: [department_id], references: [id])
  item_categories item_categories? @relation(fields: [ml_category_id], references: [id])
  pr_line_items   pr_line_items[]
  pr_approvals    pr_approvals[]
  tracking_logs   tracking_logs[]
  notifications   notifications[]
  ml_classifications ml_classifications[]

  @@index([status])
  @@index([requested_by])
  @@index([department_id])
  @@index([created_at])
}

model pr_line_items {
  id                  Int     @id @default(autoincrement()) @db.UnsignedInt
  purchase_request_id Int     @db.UnsignedInt
  description         String  @db.VarChar(500)
  unit                String  @db.VarChar(50)
  quantity            Decimal @db.Decimal(10, 2)
  unit_price          Decimal @db.Decimal(12, 2)
  category_id         Int?    @db.UnsignedInt
  specifications      String? @db.Text
  created_at          DateTime @default(now())

  purchase_requests purchase_requests @relation(fields: [purchase_request_id], references: [id], onDelete: Cascade)
  item_categories   item_categories?  @relation(fields: [category_id], references: [id])
}

model approval_steps {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  step_order   Int      @unique @db.UnsignedTinyInt
  step_name    String   @db.VarChar(100)
  role_id      Int      @db.UnsignedInt
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  roles        roles    @relation(fields: [role_id], references: [id])
  pr_approvals pr_approvals[]
}

model pr_approvals {
  id                  Int            @id @default(autoincrement()) @db.UnsignedInt
  purchase_request_id Int            @db.UnsignedInt
  approval_step_id    Int            @db.UnsignedInt
  approver_id         Int?           @db.UnsignedInt
  action              ApprovalAction @default(PENDING)
  remarks             String?        @db.Text
  acted_at            DateTime?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  purchase_requests purchase_requests @relation(fields: [purchase_request_id], references: [id], onDelete: Cascade)
  approval_steps    approval_steps    @relation(fields: [approval_step_id], references: [id])
  users             users?            @relation(fields: [approver_id], references: [id])

  @@index([purchase_request_id])
}

model tracking_logs {
  id                  Int      @id @default(autoincrement()) @db.UnsignedInt
  purchase_request_id Int      @db.UnsignedInt
  from_user_id        Int?     @db.UnsignedInt
  to_user_id          Int?     @db.UnsignedInt
  from_office         String?  @db.VarChar(150)
  to_office           String?  @db.VarChar(150)
  status_before       String?  @db.VarChar(50)
  status_after        String   @db.VarChar(50)
  action              String   @db.VarChar(100)
  remarks             String?  @db.Text
  created_at          DateTime @default(now())

  purchase_requests                              purchase_requests @relation(fields: [purchase_request_id], references: [id], onDelete: Cascade)
  users_tracking_logs_from_user_idTousers        users?            @relation("tracking_logs_from_user_idTousers", fields: [from_user_id], references: [id])
  users_tracking_logs_to_user_idTousers          users?            @relation("tracking_logs_to_user_idTousers", fields: [to_user_id], references: [id])

  @@index([purchase_request_id])
}

model notifications {
  id                  Int              @id @default(autoincrement()) @db.UnsignedInt
  user_id             Int              @db.UnsignedInt
  purchase_request_id Int?             @db.UnsignedInt
  type                NotificationType
  title               String           @db.VarChar(255)
  message             String           @db.Text
  is_read             Boolean          @default(false)
  created_at          DateTime         @default(now())

  users             users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  purchase_requests purchase_requests? @relation(fields: [purchase_request_id], references: [id], onDelete: SetNull)

  @@index([user_id, is_read])
}

model report_snapshots {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  generated_by Int      @db.UnsignedInt
  report_type  String   @db.VarChar(100)
  period_start DateTime? @db.Date
  period_end   DateTime? @db.Date
  data_json    String   @db.LongText
  created_at   DateTime @default(now())
  users        users    @relation(fields: [generated_by], references: [id])
}

model ml_classifications {
  id                  Int      @id @default(autoincrement()) @db.UnsignedInt
  purchase_request_id Int      @db.UnsignedInt
  input_text          String   @db.Text
  predicted_category  Int?     @db.UnsignedInt
  confidence          Decimal? @db.Decimal(5, 4)
  raw_output          Json?
  model_version       String?  @db.VarChar(50)
  classified_at       DateTime @default(now())

  purchase_requests purchase_requests  @relation(fields: [purchase_request_id], references: [id], onDelete: Cascade)
  item_categories   item_categories?   @relation(fields: [predicted_category], references: [id])
}

enum PRStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum NotificationType {
  PR_SUBMITTED
  PR_APPROVED
  PR_REJECTED
  PR_RETURNED
  PR_COMPLETED
  PENDING_ACTION
  SYSTEM
}
